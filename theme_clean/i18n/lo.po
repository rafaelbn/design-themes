#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_call_to_action
msgid "<b>50,000 people</b>, run Clean to grow their financial wealth."
msgstr ""
"<b>50,000 ຄົນ</b>, ໃຊ້ Clean ເພື່ອສ້າງຄວາມຮັ່ງມີທາງດ້ານການເງິນໃຫ້ເຕີບໃຫຍ່."

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_cover
msgid "<b>Sell from your couch</b>"
msgstr ""

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_title
msgid "<b>We create the perfect <br/>tailored solution for you</b>"
msgstr ""

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_carousel
msgid ""
"<br/>At any moment, you may contact our advisor through the in-app video "
"meeting system."
msgstr ""

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_carousel
msgid ""
"<br/>We integrate digital tools and solutions for better insights, enabling "
"data-driven planning."
msgstr ""

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_carousel
msgid ""
"<br/>We invest in strategic advice tailored to your<br/>\n"
"                            business problems and needs."
msgstr ""

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_features
msgid "All in one"
msgstr "ລວມທຸກຢ່າງໃນບ່ອນດຽວ"

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_three_columns
msgid ""
"Composed of 25 people from 25 to 66 years, we’re a young and dynamic "
"company. We have open positions, do not hesitate to contact us."
msgstr ""
"ປະກອບດ້ວຍທີມງານ 25 ຄົນ ທີ່ມີອາຍຸຕັ້ງແຕ່ 25 ຫາ 66 ປີ, ພວກເຮົາເປັນບໍລິສັດຄົນຮຸ່ນໃໝ່ທີ່ມີຄວາມຫ້າວຫັນ. ພວກ"
"ເຮົາມີຕຳແໜ່ງງານວ່າງ, ຢ່າລັງເລທີ່ຈະຕິດຕໍ່ຫາພວກເຮົາ."

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_features
msgid "Easy to use"
msgstr "ໃຊ້ງານງ່າຍ"

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_carousel
msgid "Efficient team processes"
msgstr "ຂະບວນການເຮັດວຽກຂອງທີມງານທີ່ມີປະສິດທິພາບ"

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_text_image
msgid "Everything you need, <br/>totally free"
msgstr "ທຸກຢ່າງທີ່ທ່ານຕ້ອງການ, <br/>ຟຣີທັງໝົດ"

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_call_to_action
msgid "Join them and make the right money move."
msgstr "ເຂົ້າຮ່ວມກັບພວກເຂົາ ແລະ ເລີ່ມຕົ້ນການຈັດການການເງິນທີ່ຖືກຕ້ອງ."

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_cover
msgid ""
"Make your finances reach a new level with our online management system. "
"<br/>Track every penny, directly from the comfort of your home."
msgstr ""
"ຍົກລະດັບການເງິນຂອງທ່ານດ້ວຍລະບົບການຈັດການອອນລາຍຂອງພວກເຮົາ. <br/>ຕິດຕາມທຸກໆລາຍຈ່າຍໄດ້ຢ່າງສະດ"
"ວກສະບາຍຈາກເຮືອນຂອງທ່ານ."

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_three_columns
msgid "Our mission"
msgstr "ພັນທະກິດຂອງພວກເຮົາ"

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_three_columns
msgid "Our team"
msgstr "ທີມງານຂອງພວກເຮົາ"

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_three_columns
msgid "Our values"
msgstr "ຄ່ານິຍົມຂອງພວກເຮົາ"

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_carousel
msgid "Personal adviser"
msgstr "ທີ່ປຶກສາສ່ວນຕົວ"

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_three_columns
msgid ""
"Provide clear and concise financial advices to make your financial wealth "
"grow. And this, completely free of charge."
msgstr ""
"ໃຫ້ຄຳແນະນຳດ້ານການເງິນທີ່ຊັດເຈນ ແລະ ກະທັດຮັດ ເພື່ອເຮັດໃຫ້ຄວາມຮັ່ງມີຂອງທ່ານເຕີບໃຫຍ່. ແລະ ສິ່ງນີ້ແມ່ນໃຫ້"
"ບໍລິການໂດຍບໍ່ເສຍຄ່າໃດໆ."

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_features
msgid "Secured"
msgstr "ຖືກປົກປ້ອງແລ້ວ"

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_carousel
msgid "Simplify things"
msgstr "ເຮັດໃຫ້ທຸກຢ່າງງ່າຍຂຶ້ນ"

#. module: theme_clean
#: model:ir.model,name:theme_clean.model_theme_utils
msgid "Theme Utils"
msgstr "ເຄື່ອງມືຊ່ວຍຈັດການທີມ (Theme Utils)"

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_text_image
msgid ""
"Track every expenses, uncover new ways to save, choose the right credit "
"cards. <br/>All those advices and much more are included and totally free of"
" charge."
msgstr ""
"ຕິດຕາມທຸກໆລາຍຈ່າຍ, ຊອກຫາວິທີໃໝ່ໆໃນການປະຢັດ, ເລືອກບັດເຄຣດິດທີ່ເໝາະສົມ. <br/>ຄຳແນະນຳທັງໝົດເຫຼົ່າ"
"ນີ້ ແລະ ອື່ນໆອີກຫຼາຍຢ່າງແມ່ນລວມຢູ່ແລ້ວ ແລະ ບໍ່ມີຄ່າໃຊ້ຈ່າຍໃດໆ."

#. module: theme_clean
#: model_terms:theme.ir.ui.view,arch:theme_clean.s_three_columns
msgid ""
"We created our company to improve the work-life balance. We believe that we "
"need to focus on our family more than our work and finances."
msgstr ""
"ພວກເຮົາຕັ້ງບໍລິສັດນີ້ຂຶ້ນມາເພື່ອປັບປຸງຄວາມສົມດຸນລະຫວ່າງການເຮັດວຽກ ແລະ ຊີວິດສ່ວນຕົວ. ພວກເຮົາເຊື່ອວ່າເຮົາຄ"
"ວນໃຫ້ຄວາມສຳຄັນກັບຄອບຄົວຫຼາຍກວ່າວຽກງານ ແລະ ການເງິນ."


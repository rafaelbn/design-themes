#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_picture
msgid "Don't rely on a book's cover,"
msgstr "Lad dig ikke narre af bogens omslag,"

#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_masonry_block_default_template

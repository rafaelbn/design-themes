#. module: theme_bookstore
#: model_terms:theme.ir.ui.view,arch:theme_bookstore.s_three_columns
msgid ""
"Discover the history of Belgium in this well-documented book with many "
"illustrations and testimonials."
msgstr ""
"Udforsk Belgiens historie i denne omfattende bog med mange billeder og "
"øjenvidneberetninger."

